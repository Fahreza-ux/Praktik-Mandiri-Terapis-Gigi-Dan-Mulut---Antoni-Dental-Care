body {
    padding-top: 60px;
    font-family: 'Segoe UI', sans-serif;
}

.hero {
    background-color: #e3f2fd;
    padding: 100px 0;
    margin-bottom: 30px;
}

.card {
    border: none;
    box-shadow: 0 4px 8px rgba(0,0,0,0.1);
    transition: 0.3s;
}

.card:hover {
    transform: translateY(-10px);
}
